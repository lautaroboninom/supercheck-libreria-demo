{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "VITE_DEMO_MODE": "1",
    "VITE_APP_NAME": "SuperCheck Librería",
    "VITE_COMPANY_LEGAL": "SuperCheck Librería",
    "VITE_SW": "0"
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
